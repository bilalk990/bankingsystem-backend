{
  "name": "@workspace/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--expose-gc --max-old-space-size=3072\" NODE_ENV=development tsx ./src/index.ts",
    "build": "npx tsx ./build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts",
    "db:push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "seed": "npx tsx ./src/scripts/seed.ts",
    "start": "node dist/index.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google-cloud/storage": "^7.19.0",
    "@types/yauzl": "^2.10.3",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "exceljs": "^4.4.0",
    "express": "^5",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "148.0.0",
    "helmet": "^8.1.0",
    "multer": "^2.0.0",
    "openai": "^6.27.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "yauzl": "^3.2.1",
    "zod": "3.25.76",
    "tsx": "^4.21.0",
    "esbuild": "0.25.11"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9"
  }
}
